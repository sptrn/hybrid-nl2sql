APP_ENV=development
API_PORT=8000
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api/v1

OCI_REGION=us-chicago-1
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..example
OCI_MODEL_ID=cohere.command-a-reasoning
OCI_SERVICE_ENDPOINT=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com
OCI_CONFIG_FILE=/root/.oci/config
OCI_AUTH_PROFILE=DEFAULT

SPARK_APP_NAME=hybrid-nl2sql
SPARK_MASTER=local[*]
SPARK_JARS_PACKAGES=org.apache.iceberg:iceberg-spark-runtime-3.5_2.12:1.8.1,org.postgresql:postgresql:42.7.7,com.mysql:mysql-connector-j:8.4.0
METADATA_MAX_NAMESPACES=25
METADATA_MAX_TABLES_PER_SOURCE=100
POLARIS_CATALOG_NAME=polaris
POLARIS_URI=http://polaris:8181/api/catalog
POLARIS_WAREHOUSE=s3://warehouse
POLARIS_SCOPE=PRINCIPAL_ROLE:ALL

MYSQL_JDBC_URL=jdbc:mysql://mysql:3306/sampledb
MYSQL_JDBC_USER=app
MYSQL_JDBC_PASSWORD=change-me
MYSQL_JDBC_DRIVER=com.mysql.cj.jdbc.Driver
MYSQL_METADATA_SCHEMAS=sampledb

POSTGRES_JDBC_URL=jdbc:postgresql://postgres:5432/sampledb
POSTGRES_JDBC_USER=app
POSTGRES_JDBC_PASSWORD=change-me
POSTGRES_JDBC_DRIVER=org.postgresql.Driver
POSTGRES_METADATA_SCHEMAS=public

ORACLE_JDBC_URL=jdbc:oracle:thin:@oracle:1521/FREEPDB1
ORACLE_JDBC_USER=app
ORACLE_JDBC_PASSWORD=change-me
ORACLE_JDBC_DRIVER=oracle.jdbc.OracleDriver
