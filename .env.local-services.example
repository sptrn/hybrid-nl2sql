APP_ENV=development
API_PORT=8000
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api/v1

OCI_MODEL_ID=cohere.command-a-reasoning

SPARK_APP_NAME=hybrid-nl2sql-local-lab
SPARK_MASTER=local[*]
SPARK_JARS_PACKAGES=org.postgresql:postgresql:42.7.7,com.mysql:mysql-connector-j:8.4.0
METADATA_MAX_NAMESPACES=25
METADATA_MAX_TABLES_PER_SOURCE=100
POLARIS_URI=
POLARIS_WAREHOUSE=
POLARIS_SCOPE=

