APP_ENV=development
API_PORT=8000
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api/v1

OCI_MODEL_ID=cohere.command-a-reasoning

SPARK_APP_NAME=hybrid-nl2sql-local-lab
SPARK_MASTER=local[*]
SPARK_JARS_PACKAGES=org.apache.iceberg:iceberg-aws-bundle:1.10.1,org.postgresql:postgresql:42.7.7,com.mysql:mysql-connector-j:8.4.0
SPARK_ICEBERG_RUNTIME_PACKAGE=org.apache.iceberg:iceberg-spark-runtime-3.5_2.12:1.10.1
METADATA_MAX_NAMESPACES=50
METADATA_MAX_TABLES_PER_SOURCE=100
POLARIS_URI=http://127.0.0.1:18181/api/catalog
POLARIS_WAREHOUSE=quickstart_catalog
POLARIS_SCOPE=PRINCIPAL_ROLE:ALL
POLARIS_CREDENTIAL=root:s3cr3t
POLARIS_TOKEN=
POLARIS_ACCESS_DELEGATION=
POLARIS_TOKEN_REFRESH_ENABLED=true
POLARIS_CLIENT_REGION=irrelevant
POLARIS_CATALOG_OPTIONS="s3.endpoint=http://127.0.0.1:19000;s3.path-style-access=true;s3.access-key-id=polaris_root;s3.secret-access-key=polaris_pass;rest.auth.type=oauth2;oauth2-server-uri=http://127.0.0.1:18181/api/catalog/v1/oauth/tokens"

MYSQL_JDBC_URL=jdbc:mysql://127.0.0.1:13306/sampledb
MYSQL_JDBC_USER=app
MYSQL_JDBC_PASSWORD=change-me
MYSQL_JDBC_DRIVER=com.mysql.cj.jdbc.Driver
MYSQL_METADATA_SCHEMAS=sampledb

POSTGRES_JDBC_URL=jdbc:postgresql://127.0.0.1:15432/sampledb
POSTGRES_JDBC_USER=app
POSTGRES_JDBC_PASSWORD=change-me
POSTGRES_JDBC_DRIVER=org.postgresql.Driver
POSTGRES_METADATA_SCHEMAS=public

ORACLE_JDBC_URL=
ORACLE_JDBC_USER=
ORACLE_JDBC_PASSWORD=
ORACLE_JDBC_DRIVER=oracle.jdbc.OracleDriver

POLARIS_REALM=POLARIS
POLARIS_BOOTSTRAP_CLIENT_ID=root
POLARIS_BOOTSTRAP_CLIENT_SECRET=s3cr3t
POLARIS_DEFAULT_BASE_LOCATION=s3://bucket123
POLARIS_STORAGE_ENDPOINT=http://127.0.0.1:19000
POLARIS_STORAGE_ENDPOINT_INTERNAL=http://rustfs:9000
